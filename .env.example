# Copy this file to .env and fill in real values. .env is gitignored.

# Flask session signing key. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Telegram alerting (from @BotFather and your chat/group id)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Zabbix API
ZABBIX_URL=https://zabbix.example.com/api_jsonrpc.php
ZABBIX_USER=admin
ZABBIX_PASS=

# Alarm threshold (Zabbix severity that counts as CRITICAL red+sound+Telegram):
# 5 Disaster | 4 High | 3 Average (default) | 2 Warning. Below it = amber/silent.
ZABBIX_ALARM_MIN_SEVERITY=3
